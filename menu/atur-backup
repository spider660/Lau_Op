# Warna untuk output agar lebih menarik
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Fungsi untuk mengatur/mengubah jadwal
set_schedule() {
    clear
    echo "============================================="
    echo "       Set or Change Backup Schedule          "
    echo "============================================="
    echo ""
    
    read -p "Enter the time for backup (0-23): " backup_hour
    if ! [[ "$backup_hour" =~ ^[0-9]+$ ]] || [ "$backup_hour" -lt 0 ] || [ "$backup_hour" -gt 23 ]; then
        echo -e "${RED}Error: Invalid time. Please enter a number between 0 and 23.${NC}"
        return 1
    fi

    read -p "Enter minutes for backup (0-59): " backup_minute
    if ! [[ "$backup_minute" =~ ^[0-9]+$ ]] || [ "$backup_minute" -lt 0 ] || [ "$backup_minute" -gt 59 ]; then
        echo -e "${RED}Error: Invalid minutes. Please enter a number between 0 and 59.${NC}"
        return 1
    fi

    read -p "Masukkan path lengkap ke skrip backup (cth: /root/manual-backup.sh): " backup_script_path

    # Jika file belum ada, buat folder & file-nya
    if [ ! -f "$backup_script_path" ]; then
        echo -e "${YELLOW}File skrip di '$backup_script_path' tidak ditemukan.${NC}"
        read -p "Ingin membuat file tersebut sekarang? (y/n): " confirm_create
        if [[ "$confirm_create" =~ ^[Yy]$ ]]; then
            folder_path=$(dirname "$backup_script_path")
            mkdir -p "$folder_path"
            echo -e "#!/bin/bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# System Request : Debian 9+/Ubuntu 18.04+/20+
# Develovers » ŞƤƗĐ€Ř
# Email      » laubuoy@gmail.com
# telegram   » https://t.me/spid_3r
# whatsapp   » wa.me/+254112011036
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# Skrip backup otomatis\n\necho \"Backup dijalankan pada \$(date)\"" > "$backup_script_path"
            chmod +x "$backup_script_path"
            echo -e "${GREEN}File skrip '$backup_script_path' telah dibuat.${NC}"
        else
            echo -e "${RED}Operation cancelled.${NC}"
            return 1
        fi
    fi

    # Membuat baris perintah cron baru
    local cron_command="$backup_minute $backup_hour * * * /bin/bash $backup_script_path"

    # Menghapus jadwal lama untuk skrip ini (jika ada) dan menambahkan yang baru
    (crontab -l 2>/dev/null | grep -v "$backup_script_path" ; echo "$cron_command") | crontab -

    echo ""
    echo -e "${GREEN}Success! The backup schedule has been set.${NC}"
    echo "------------------------------------------------"
    echo -e "Backup will run every day at ${YELLOW}${backup_hour}:${backup_minute}${NC}."
    echo -e "Command in crontab: ${YELLOW}${cron_command}${NC}"
    echo "------------------------------------------------"
}

# Fungsi untuk mematikan jadwal
disable_schedule() {
    clear
    echo "============================================="
    echo "           Turn off Schedule Backup            "
    echo "============================================="
    echo ""

    read -p "Enter the full path of the backup script whose schedule you want to disable: " backup_script_path

    if [ -z "$backup_script_path" ]; then
        echo -e "${RED}Error: Script path cannot be empty.${NC}"
        return 1
    fi

    crontab -l 2>/dev/null | grep -q "$backup_script_path"
    if [ $? -ne 0 ]; then
        echo -e "${YELLOW}Information: Schedule for script '$backup_script_path' not found.${NC}"
        return 1
    fi

    (crontab -l 2>/dev/null | grep -v "$backup_script_path") | crontab -

    echo ""
    echo -e "${GREEN}Success! The backup schedule for script '$backup_script_path' has been disabled.${NC}"
    echo "------------------------------------------------"
}

# --- Menu Utama Skrip ---
while true; do
    clear
    echo "============================================="
    echo "       Automatic Backup Schedule Management      "
    echo "============================================="
    echo -e "Select Options:"
    echo -e "1. ${GREEN}Set/Change Backup Schedule${NC}"
    echo -e "2. ${RED}Turn Off Backup Schedule${NC}"
    echo -e "3. ${CYAN}Exit${NC}"
    echo "============================================="
read -p "Enter your choices [1-3]: " choice
    case $choice in
        1)
            set_schedule
            read -p "Press [Enter] to return to the menu..."
            ;;
        2)
            disable_schedule
            read -p "Press [Enter] to return to the menu..."
            ;;
        3)
            echo "Go off script."
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid selection. Please try again.${NC}"
            sleep 2
            ;;
    esac
done
